# ── Client-side (safe to expose, prefixed VITE_) ──────────────────
# Get from: Supabase dashboard → Settings → API → Project URL + anon key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Server-side only (never prefix with VITE_) ────────────────────
# Groq: https://console.groq.com → API Keys
GROQ_API_KEY=your-groq-api-key-here

# Supabase service key (bypasses RLS — server only, edge function only)
# Get from: Supabase dashboard → Settings → API → service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
